{
  "expo": {
    "name": "Pippogram",
    "slug": "pippogram",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0F0F13"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pippogram.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Pippogram needs your microphone for push-to-talk audio.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F13"
      },
      "package": "com.pippogram.app",
      "permissions": [
        "RECORD_AUDIO",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": null,
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Pippogram needs your microphone for push-to-talk."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0a07bf09-270e-47d7-9fdc-08fdb3a5e6e0"
      }
    }
  }
}
